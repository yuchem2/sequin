{
  "name": "sequin",
  "private": "true",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:all": "concurrently \"pnpm dev:db\" \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "pnpm --filter @sequin/client dev",
    "dev:server": "pnpm --filter @sequin/server dev",
    "dev:db": "docker compose up -d",
    "build": "pnpm --filter @sequin/shared build && pnpm -r build",
    "build:client": "pnpm --filter @sequin/client build",
    "build:server": "pnpm --filter @sequin/server build",
    "lint": "eslint packages/*/src --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,css}\"",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @sequin/server db:migrate",
    "db:studio": "pnpm --filter @sequin/server db:studio",
    "db:seed": "pnpm --filter @sequin/server db:seed",
    "clean": "rm -rf packages/*/node_modules packages/*/.next packages/*/dist node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "typescript": "^5.7.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.20.0"
}
